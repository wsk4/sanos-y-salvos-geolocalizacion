# ===================================================================
# .env.example - Plantilla de Entorno Local para Desarrollo
# IMPORTANTE: Copia este archivo como '.env' y completa los valores.
# ===================================================================

# === SERVER CONFIGURATION ===
SERVER_PORT=8081

# === DATABASE CONFIGURATION (PostgreSQL + PostGIS) ===
# Para desarrollo local (standalone), DB_HOST suele ser localhost.
# Si usas Docker Compose, DB_HOST debe coincidir con el nombre del servicio (ej. postgres-db).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanosysalvos_mascotas
DB_USERNAME=tu_usuario_postgres
DB_PASSWORD=tu_password_seguro

# === EXTERNAL API (LocationIQ) ===
# Obtén tu token de desarrollo gratuito en: https://my.locationiq.com/dashboard
LOCATIONIQ_API_KEY=ingresa_tu_api_key_aqui
LOCATIONIQ_API_URL=https://us1.locationiq.com/v1/search.php